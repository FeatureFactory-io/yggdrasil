{
  "version": 1,
  "hooks": {
    "afterFileEdit": [
      {
        "command": "python3 .cursor/hooks/sync-feature-spec.py after-edit"
      }
    ],
    "afterTabFileEdit": [
      {
        "command": "python3 .cursor/hooks/sync-feature-spec.py after-edit"
      }
    ],
    "postToolUse": [
      {
        "command": "python3 .cursor/hooks/sync-feature-spec.py post-tool",
        "matcher": "Write|StrReplace|EditNotebook"
      }
    ],
    "stop": [
      {
        "command": "python3 .cursor/hooks/sync-feature-spec.py stop",
        "loop_limit": 1
      }
    ]
  }
}
