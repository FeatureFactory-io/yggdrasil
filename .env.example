# Copy to .env and fill in values for local development.
# Never commit .env to version control.

# Django
DEBUG=True
SECRET_KEY=dev-only-insecure-key-change-in-prod
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (docker-compose default)
DATABASE_URL=postgresql://yggdrasil:yggdrasil@localhost:5432/yggdrasil

# Redis (docker-compose default; used by Celery broker + Django cache)
REDIS_URL=redis://localhost:6379/0

# LLM provider: ollama | anthropic | openai
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama:11434   # http://localhost:11434 when running Ollama natively
LLM_OLLAMA_MODEL=qwen3:14b

# Cloud LLM keys (required only if LLM_PROVIDER != ollama)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Yggdrasil server URL (used by Ratatosk CLI and MCP facade)
YGGDRASIL_SERVER_URL=http://localhost:8000

# Logging (leave blank to use defaults: logs/app.log, logs/gui.log, logs/consumption.log)
LOG_LEVEL=DEBUG
