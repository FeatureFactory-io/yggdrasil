<mxfile host="app.diagrams.net">
  <diagram name="Domain Model" id="domain-model">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="element" value="Element (Vertex)&#xa;stereotype, properties JSONB" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="80" y="120" width="160" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="relationship" value="Relationship (Edge)&#xa;from → to, stereotype" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="320" y="120" width="160" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="stereotype" value="Stereotype&#xa;schema, edge rules" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="80" y="280" width="140" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="package" value="Package&#xa;view root" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="260" y="280" width="120" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="diagram" value="Diagram&#xa;Cytoscape layout" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="420" y="280" width="140" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="changeset" value="ChangeSet&#xa;staged writes" style="rounded=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="200" y="400" width="120" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="e1" style="endArrow=classic;" edge="1" parent="1" source="element" target="relationship">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e2" style="endArrow=classic;" edge="1" parent="1" source="element" target="stereotype">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e3" style="endArrow=classic;" edge="1" parent="1" source="element" target="package">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e4" style="endArrow=classic;" edge="1" parent="1" source="package" target="diagram">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e5" style="endArrow=classic;dashed=1;" edge="1" parent="1" source="changeset" target="element">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="MVP Flow" id="mvp-flow">
    <mxGraphModel dx="1400" dy="600" grid="1" gridSize="10">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="auth" value="AUTH-LOGIN-1" style="rounded=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="200" width="120" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="view" value="VIEW-BROWSE-1" style="rounded=1;strokeWidth=3;" vertex="1" parent="1">
          <mxGeometry x="200" y="200" width="140" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="elist" value="ELEMENT-LIST+FIND-1" style="rounded=1;strokeWidth=3;" vertex="1" parent="1">
          <mxGeometry x="380" y="120" width="160" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="eview" value="ELEMENT-VIEW_ELEMENT-1" style="rounded=1;" vertex="1" parent="1">
          <mxGeometry x="580" y="120" width="180" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="clist" value="CHANGESET-LIST+FIND-1" style="rounded=1;strokeWidth=3;" vertex="1" parent="1">
          <mxGeometry x="380" y="280" width="180" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="chat" value="CHAT-ASSIST-1" style="rounded=1;" vertex="1" parent="1">
          <mxGeometry x="380" y="360" width="140" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="f1" style="endArrow=classic;strokeWidth=2;" edge="1" parent="1" source="auth" target="view">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="f2" style="endArrow=classic;" edge="1" parent="1" source="view" target="elist">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="f3" style="endArrow=classic;" edge="1" parent="1" source="elist" target="eview">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="f4" style="endArrow=classic;" edge="1" parent="1" source="view" target="clist">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="f5" style="endArrow=classic;" edge="1" parent="1" source="view" target="chat">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
